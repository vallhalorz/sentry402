{
  "name": "@sentry402/eliza-plugin",
  "version": "0.1.1",
  "description": "ElizaOS plugin: pre-flight sanctions firewall for AI agents. Wraps native transfer actions with a $0.02 x402 call to Sentry402 — every agent gets allow / warn / block before signing. Multi-chain (EVM + Solana) via GoldRush + Helius DAS.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test:smoke": "node scripts/smoke.mjs"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "keywords": [
    "elizaos",
    "elizaos-plugin",
    "eliza-plugin",
    "ai-agent",
    "agent-firewall",
    "agent-compliance",
    "compliance",
    "sanctions",
    "ofac",
    "x402",
    "sentry402",
    "wallet-risk",
    "solana",
    "evm"
  ],
  "author": "vallhalorz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vallhalorz/sentry402",
    "directory": "eliza-plugin"
  },
  "homepage": "https://sentry402.vercel.app/#firewall",
  "peerDependencies": {
    "@elizaos/core": "^0.1.0"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
